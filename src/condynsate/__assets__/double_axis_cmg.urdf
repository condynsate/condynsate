<?xml version="1.0" ?>
<robot name="gyro">


    <!-- ########### MATERIALS ########### -->
    <material name="chassis">
        <color rgba="0.588 0.862 0.972 1" />
    </material>
    
    <material name="outer">
        <color rgba="0.380 0.796 0.956 1" />
    </material>
    
    <material name = "inner">
        <color rgba = "0.031 0.309 0.415 1" />
    </material>
  
    <material name = "wheel">
        <color rgba = "0.913 0.443 0.196 1" />
    </material>

    <!-- ########### LINKS ########### -->
	<link name="A" concave="yes">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="spacecraft_chassis_19-ODx18-ID_cen-orig.stl" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name = "chassis"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="1.45"/>
            <inertia ixx="0.00828" ixy="0" ixz="0" iyy="0.00828" iyz="0" izz="0.00828"/>
        </inertial>
    </link>
	
    <link name="B" concave="yes">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="double_gyroring_18-Wx14-ODx12-IDx2-T_cen_orig.stl" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name = "outer"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.221"/>
            <inertia ixx="0.000476" ixy="0" ixz="0" iyy="0.000937" iyz="0" izz="0.000476"/>
        </inertial>
    </link>

    <link name="C" concave="yes">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="double_gyroring_12-Wx8-ODx6-IDx2-T_cen-orig.stl" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name = "inner"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.119"/>
            <inertia ixx="0.000148" ixy="0" ixz="0" iyy="0.0000777" iyz="0" izz="0.0000777"/>
        </inertial>
    </link>

    <link name="flywheel">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="double_gyrocore_6-Wx5.5-ODx3-T_cen-orig.stl" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name = "wheel"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.622"/>
            <inertia ixx="0.000164" ixy="0" ixz="0" iyy="0.000235" iyz="0" izz="0.000164"/>
        </inertial>
    </link>


    <!-- ########### JOINTS ########### -->
	<joint name="A_to_B" type="continuous">
        <parent link = "A" />
        <child link = "B" />
        <origin rpy="0 0 0" xyz = "0 0 0" />
        <axis xyz = "0 1 0" />
    </joint>
	
    <joint name="B_to_C" type="continuous">
        <parent link = "B" />
        <child link = "C" />
        <origin rpy="0 0 0" xyz = "0 0 0" />
        <axis xyz = "1 0 0" />
    </joint>

    <joint name="C_to_flywheel" type="continuous">
        <parent link = "C" />
        <child link = "flywheel" />
        <origin rpy="0 0 0" xyz = "0 0 0" />
        <axis xyz = "0 1 0" />
    </joint>



</robot>

