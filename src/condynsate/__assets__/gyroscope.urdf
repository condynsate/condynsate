<?xml version="1.0" ?>
<robot name="gyro">


    <!-- ########### MATERIALS ########### -->

    <material name="industrial">
        <color rgba="0.114 0.345 0.655 1" />
    </material>
    
    <material name="arches">
        <color rgba="0 0.624 0.831 1" />
    </material>
    
    <material name = "heritage">
        <color rgba = "0.961 0.510 0.118 1" />
    </material>
  

    <!-- ########### LINKS ########### -->
	<link name="base">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="Cylinder_1x1_lower_origin.stl" scale="1 1 0.1"/>
            </geometry>
            <material name = "industrial"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0"/>
            <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
        </inertial>
    </link>
	
    <link name="A" concave="yes">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="gyrochassis-rotational_XZ-Z_20-Hx20-ODx18-IDx2-T_cen-orig.stl" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name = "arches"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.322"/>
            <inertia ixx="0.00147" ixy="0" ixz="0" iyy="0.00291" iyz="0" izz="0.00147"/>
        </inertial>
    </link>

    <link name="B" concave="yes">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="gyroring_XY-X_18-Wx14-ODx12-IDx2-T_cen-orig.stl" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name = "industrial"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.221"/>
            <inertia ixx="0.000476" ixy="0" ixz="0" iyy="0.000476" iyz="0" izz="0.000937"/>
        </inertial>
    </link>

    <link name="C" concave="yes">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="gyroring_YZ-Y_12-Wx8-ODx6-IDx2-T_cen-orig.stl" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name = "arches"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.119"/>
            <inertia ixx="0.000148" ixy="0" ixz="0" iyy="0.0000777" iyz="0" izz="0.0000777"/>
        </inertial>
    </link>

    <link name="flywheel">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="gyrocore_XY-Z_6-Wx5.5-ODx3-T_cen-orig.stl" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name = "heritage"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.622"/>
            <inertia ixx="0.000164" ixy="0" ixz="0" iyy="0.000164" iyz="0" izz="0.000235"/>
        </inertial>
    </link>


    <!-- ########### JOINTS ########### -->
	    <joint name="base_to_A" type="continuous">
        <parent link = "base" />
        <child link = "A" />
        <origin rpy="0 0 0" xyz = "0 0 2" />
        <axis xyz = "0 0 1" />
    </joint>
	
    <joint name="A_to_B" type="continuous">
        <parent link = "A" />
        <child link = "B" />
        <origin rpy="0 0 0" xyz = "0 0 0" />
        <axis xyz = "1 0 0" />
    </joint>

    <joint name="B_to_C" type="continuous">
        <parent link = "B" />
        <child link = "C" />
        <origin rpy="0 0 0" xyz = "0 0 0" />
        <axis xyz = "0 1 0" />
    </joint>

    <joint name="C_to_flywheel" type="continuous">
        <parent link = "C" />
        <child link = "flywheel" />
        <origin rpy="0 0 0" xyz = "0 0 0" />
        <axis xyz = "0 0 1" />
    </joint>



</robot>

