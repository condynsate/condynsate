<?xml version="1.0" ?>
<robot name="gyro">


    <!-- ########### MATERIALS ########### -->

    <material name="storm">
        <color rgba="0.439 0.451 0.447 1" />
    </material>

    <material name="industrial">
        <color rgba="0.114 0.345 0.655 1" />
    </material>
    
    <material name="arches">
        <color rgba="0 0.624 0.831 1" />
    </material>
    
    <material name = "heritage">
        <color rgba = "0.961 0.510 0.118 1" />
    </material>
  

    <!-- ########### LINKS ########### -->
	<link name="base" concave="yes">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="gyrochassis-fixed_20-ODx18-ID_cen-orig.stl" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name = "storm"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0"/>
            <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
        </inertial>
    </link>
	
	<link name="massrod">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="Cylinder_1x1_lower_origin.stl" scale="0.1 0.1 0.7"/>
            </geometry>
            <material name = "industrial"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0"/>
            <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
        </inertial>
		<collision>
			<geometry>
				<mesh filename="Cylinder_1x1_lower_origin.stl" scale="0.1 0.1 0.7"/>
			</geometry>
		</collision>
    </link>
	
	<link name="mass">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="Sphere_1_center_origin.stl" scale="0.25 0.25 0.25"/>
            </geometry>
            <material name = "industrial"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.0221"/>
            <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
        </inertial>
    </link>
	
    <link name="A" concave="yes">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="gyroring_YZ-Y_18-Wx14-ODx12-IDx2-T_cen-orig.stl" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name = "industrial"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.221"/>
            <inertia ixx="0.000937" ixy="0" ixz="0" iyy="0.000476" iyz="0" izz="0.000476"/>
        </inertial>
    </link>

    <link name="B" concave="yes">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="gyroring_XZ-Z_12-Wx8-ODx6-IDx2-T_cen-orig.stl" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name = "arches"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.119"/>
            <inertia ixx="0.0000777" ixy="0" ixz="0" iyy="0.000148" iyz="0" izz="0.0000777"/>
        </inertial>
    </link>

    <link name="flywheel">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="gyrocore_YZ-X_6-Wx5.5-ODx3-T_cen-orig.stl" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name = "heritage"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.622"/>
            <inertia ixx="0.000235" ixy="0" ixz="0" iyy="0.000164" iyz="0" izz="0.000164"/>
        </inertial>
    </link>


    <!-- ########### JOINTS ########### -->
	<joint name="base_to_A" type="continuous">
        <parent link = "base" />
        <child link = "A" />
        <origin rpy="0 0 0" xyz = "0 0 0" />
        <axis xyz = "0 1 0" />
    </joint>
	
    <joint name="A_to_massrod" type="fixed">
        <parent link = "A" />
        <child link = "massrod" />
        <origin rpy="0 0 0" xyz = "0 0 0.7" />
    </joint>
	
	<joint name="massrod_to_mass" type="fixed">
        <parent link = "massrod" />
        <child link = "mass" />
        <origin rpy="0 0 0" xyz = "0 0 0.8" />
    </joint>
	
    <joint name="A_to_B" type="continuous">
        <parent link = "A" />
        <child link = "B" />
        <origin rpy="0 0 0" xyz = "0 0 0" />
        <axis xyz = "0 0 1" />
    </joint>

    <joint name="B_to_flywheel" type="continuous">
        <parent link = "B" />
        <child link = "flywheel" />
        <origin rpy="0 0 0" xyz = "0 0 0" />
        <axis xyz = "1 0 0" />
    </joint>



</robot>

